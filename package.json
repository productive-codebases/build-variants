{
  "name": "@productive-codebases/build-variants",
  "version": "1.6.0",
  "description": "Type-safe style variant builder for CSS-in-JS objects.",
  "author": "Alexis MINEAUD",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/productive-codebases/build-variants.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rm -rf dist && tsc --project tsconfig.build.json",
    "check": "tsc --noEmit --project tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "prepublishOnly": "npm run check && npm run lint && npm t && npm run build",
    "test": "jest --runInBand"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@emotion/react": "^11.14.0",
    "@types/jest": "^30.0.0",
    "@types/lodash.mergewith": "^4.6.9",
    "@types/node": "^24.10.1",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.0",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "lodash.mergewith": "^4.6.2"
  },
  "dependencies": {}
}
